# ─────────────────────────────────────────────────────────────
#  SORTEOS PLATFORM — Variables de entorno
#  Copiá este archivo a .env y completá los valores
#  NUNCA subas .env a GitHub
# ─────────────────────────────────────────────────────────────

# APP
NODE_ENV=development
PORT=3001
BASE_URL=http://localhost:3001
FRONTEND_URL=http://localhost:3000

# BASE DE DATOS
# Para desarrollo local usar estos valores (coinciden con docker-compose)
DATABASE_URL=postgresql://sorteos:sorteos_dev_2025@localhost:5432/sorteos_dev
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# REDIS
REDIS_URL=redis://localhost:6379
# Tiempo de reserva de números en segundos (600 = 10 minutos)
REDIS_TTL_RESERVA=600

# AUTH — Generá secretos con: openssl rand -base64 64
JWT_SECRET=REEMPLAZAR_CON_SECRET_SEGURO
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=REEMPLAZAR_CON_OTRO_SECRET_DIFERENTE
JWT_REFRESH_EXPIRES_IN=7d

# MERCADOPAGO — https://www.mercadopago.com.ar/developers
# Usar claves de TEST para desarrollo, PRODUCCION para producción
MP_ACCESS_TOKEN=TEST-REEMPLAZAR
MP_PUBLIC_KEY=TEST-REEMPLAZAR
MP_WEBHOOK_SECRET=REEMPLAZAR_CON_FIRMA_DE_WEBHOOK

# ENCRIPTACIÓN DE DATOS SENSIBLES EN DB
# Generar con: openssl rand -hex 32
ENCRYPTION_KEY=REEMPLAZAR_CON_32_BYTES_HEX

# STORAGE — Cloudflare R2 (recomendado) o AWS S3
R2_ACCOUNT_ID=
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_BUCKET_NAME=sorteos-comprobantes
R2_PUBLIC_URL=https://comprobantes.tu-dominio.com

# EMAIL — https://resend.com
RESEND_API_KEY=re_REEMPLAZAR
EMAIL_FROM=noreply@tu-dominio.com

# MONITOREO — https://sentry.io
SENTRY_DSN=
